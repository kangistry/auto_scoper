# Streamlit Secrets Configuration
# ================================
# Copy this to secrets.toml for local testing, OR
# Add these values in Streamlit Cloud: Settings > Secrets
#
# DO NOT commit secrets.toml to git!

# Dify API Configuration
api_key = "app-your-api-key-here"
base_url = "https://dify.uplearn.co.uk/v1"

# Authentication Cookies (from Chrome DevTools)
[cookies]
"__Host-GCP_IAP_AUTH_TOKEN_220F89A4D796F67F" = "your-iap-token-here"
"auth-token" = "your-auth-token-here"
